rules_version = '2';
// Vision Guard — Règles Firestore
// Phase test : tout utilisateur authentifié peut lire/écrire.
// À resserrer en production avec les règles RBAC complètes (voir firestore.rules.production).
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
