# Vision Guard AI Engine — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs

# Firebase (à fournir une fois le projet Firestore/Storage créé)
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_SERVICE_ACCOUNT_KEY=./firebase-service-account.json

# YOLOv11
# Options : yolo11n.pt | yolo11s.pt | yolo11m.pt | yolo11l.pt | yolo11x.pt
YOLO_MODEL=yolo11m.pt
# Options : cpu | cuda | mps (Apple Silicon)
YOLO_DEVICE=cpu
YOLO_CONF=0.45
YOLO_IOU=0.50
YOLO_IMG_SIZE=640

# Streaming
FRAME_SKIP=3
SNAPSHOT_ON_DETECT=true
MAX_STREAMS=16

# API
API_HOST=0.0.0.0
API_PORT=8000

# OAuth callbacks (Ring, Nest)
VISIONGUARD_CALLBACK_URL=https://app.visionguard.ai
RING_CLIENT_ID=
GOOGLE_SDM_PROJECT_ID=

# Stream server URL (utilisé par startStream Cloud Function)
STREAM_SERVER_URL=http://localhost:8000
